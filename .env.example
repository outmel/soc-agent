# Slack app (api.slack.com/apps)
# Bot scopes: app_mentions:read, assistant:write, channels:history, channels:read,
#             chat:write, commands, im:history, im:read
# User scopes (optional, for RTS correlation): search:read.public, search:read.private,
#             search:read.im, search:read.mpim, search:read.files, search:read.users
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_USER_TOKEN=xoxp-your-user-token

# LLM triage + Q&A
DEEPSEEK_API_KEY=sk-your-key

# Threat intel enrichment
VIRUSTOTAL_API_KEY=your-key
ABUSEIPDB_API_KEY=your-key

# Channel routing (channel IDs, not names)
SLACK_CHANNEL_ID=C0XXXXXXXXX
SLACK_CHANNEL_P1=C0XXXXXXXXX
SLACK_CHANNEL_P2=C0XXXXXXXXX
SLACK_CHANNEL_P3=C0XXXXXXXXX
SLACK_CHANNEL_GENERAL=C0XXXXXXXXX

# Auth secrets - pick long random strings
SPLUNK_WEBHOOK_SECRET=
GITHUB_WEBHOOK_SECRET=
DASHBOARD_TOKEN=

# Optional
# PUBLIC_URL=https://your-domain.example
# DATA_DIR=/data
